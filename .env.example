# Supabase — Project Settings → Database (use "Transaction" pooler for DATABASE_URL in serverless)
DATABASE_URL="postgresql://postgres.url:[YOUR-PASSWORD]@aws-[region].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.url:[YOUR-PASSWORD]@aws-[region].pooler.supabase.com:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL="https://url.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Server-only — never expose to the browser. Required for signup role metadata + Storage uploads.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Optional: emails matching this (case-insensitive) become admin on signup
ADMIN_EMAIL="example@domain.com"

# Optional: set to "false" to require email confirmation before login
# SUPABASE_AUTOCONFIRM_NEW_USERS="false"

# Optional: Supabase Storage bucket for listing photos (create the bucket in Dashboard → Storage)
# SUPABASE_STORAGE_BUCKET="listing-images"
