// Prisma schema — Waste Marketplace (Phase 2: offers, comments, chat, pricing)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  customer
  buyer
  admin
  driver
}

enum WasteType {
  PLASTIC
  PAPER
  CARDBOARD
  METAL
  GLASS
  E_WASTE
  ORGANIC
  MIXED
  CUSTOM
}

enum ListingStatus {
  open
  accepted
  in_progress
  completed
  cancelled
  no_show
  reopened
}

enum OfferStatus {
  pending
  accepted
  declined
  withdrawn
}

enum TransportStatus {
  scheduled
  in_transit
  completed
  cancelled
}

enum TransactionStatus {
  pending
  paid
  failed
  refunded
}

enum TransactionType {
  deposit
  payout
  fee
}

enum PickupJobStatus {
  none
  available
  claimed
  assigned
  completed
}

enum CommissionKind {
  percent
  fixed
}

/// Application profile keyed to auth.users.id (Supabase Auth).
model User {
  id            String   @id @db.Uuid
  name          String
  email         String   @unique
  phone         String?
  role          UserRole
  address       String?
  vehicleType   String?  @map("vehicle_type")
  licenseNumber String?  @map("license_number")
  availability  String?
  avatarUrl     String?  @map("avatar_url")
  zipCode       String?  @map("zip_code")
  profileLat    Float?   @map("profile_lat")
  profileLng    Float?   @map("profile_lng")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  listingsPosted   WasteListing[]    @relation("SellerListings")
  listingsAccepted WasteListing[]    @relation("AcceptedBy")
  offersMade       Offer[]
  comments         ListingComment[]
  buyerConversations Conversation[]
  messagesSent     Message[]
  driverJobs       TransportJob[]    @relation("DriverJobs")
  deliveryRequests TransportJob[]    @relation("DeliveryRequests")
  payerTransactions Transaction[]    @relation("PayerTransactions")
  payeeTransactions Transaction[]    @relation("PayeeTransactions")
  reviewsGiven     Review[]         @relation("reviews_from")
  reviewsReceived  Review[]         @relation("reviews_to")
  notifications    Notification[]
  assignedPickups  WasteListing[]  @relation("AssignedDriverPickups")

  @@map("users")
}

model WasteListing {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  wasteType      WasteType     @map("waste_type")
  quantity       String
  description    String?
  images         String[]      @default([])
  address        String
  askingPrice    Decimal       @map("asking_price") @db.Decimal(12, 2)
  currency       String        @default("USD")
  status         ListingStatus @default(open)
  acceptedById   String?       @map("accepted_by") @db.Uuid
  acceptedAt     DateTime?     @map("accepted_at")
  pickupDeadlineAt DateTime?   @map("pickup_deadline_at")
  pickupExtendedAt DateTime?   @map("pickup_extended_at")
  deliveryAvailable Boolean    @default(false) @map("delivery_available")
  deliveryFee    Decimal?      @map("delivery_fee") @db.Decimal(12, 2)
  latitude       Float?
  longitude      Float?
  deliveryRequired Boolean     @default(false) @map("delivery_required")
  pickupJobStatus PickupJobStatus @default(none) @map("pickup_job_status")
  assignedDriverId String?     @map("assigned_driver_id") @db.Uuid
  driverCommissionAmount Decimal? @map("driver_commission_amount") @db.Decimal(12, 2)
  driverCommissionPercent Decimal? @map("driver_commission_percent") @db.Decimal(5, 2)
  commissionKind CommissionKind? @map("commission_kind")
  pickupZip      String?      @map("pickup_zip")
  noShowReason   String?       @map("no_show_reason")
  reopenedAt     DateTime?     @map("reopened_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  seller User               @relation("SellerListings", fields: [userId], references: [id], onDelete: Cascade)
  acceptor    User?              @relation("AcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)
  assignedDriver User?         @relation("AssignedDriverPickups", fields: [assignedDriverId], references: [id], onDelete: SetNull)
  offers      Offer[]
  comments    ListingComment[]
  conversations Conversation[]
  transportJobs TransportJob[]
  transactions Transaction[]
  reviews      Review[]

  @@index([status])
  @@index([userId])
  @@index([acceptedById])
  @@map("waste_listings")
}

model Offer {
  id        String      @id @default(uuid()) @db.Uuid
  listingId String      @map("listing_id") @db.Uuid
  buyerId   String      @map("buyer_id") @db.Uuid
  amount    Decimal     @db.Decimal(12, 2)
  currency  String      @default("USD")
  status    OfferStatus @default(pending)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  listing WasteListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User         @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([buyerId])
  @@map("offers")
}

model ListingComment {
  id        String   @id @default(uuid()) @db.Uuid
  listingId String   @map("listing_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  listing WasteListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_comments")
}

/// One thread per listing + buyer; seller is listing owner.
model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  listingId String   @map("listing_id") @db.Uuid
  buyerId   String   @map("buyer_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  listing  WasteListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User         @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([listingId, buyerId])
  @@index([listingId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model TransportJob {
  id           String          @id @default(uuid()) @db.Uuid
  listingId    String          @map("listing_id") @db.Uuid
  driverId     String?         @map("driver_id") @db.Uuid
  requesterId  String?         @map("requester_id") @db.Uuid
  scheduledAt  DateTime        @map("scheduled_at")
  completedAt  DateTime?       @map("completed_at")
  status       TransportStatus @default(scheduled)
  deliveryFee  Decimal?        @map("delivery_fee") @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  listing   WasteListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  driver    User?         @relation("DriverJobs", fields: [driverId], references: [id], onDelete: Cascade)
  requester User?         @relation("DeliveryRequests", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([driverId])
  @@index([requesterId])
  @@map("transport_jobs")
}

model Transaction {
  id         String            @id @default(uuid()) @db.Uuid
  listingId  String?           @map("listing_id") @db.Uuid
  payerId    String            @map("payer_id") @db.Uuid
  payeeId    String            @map("payee_id") @db.Uuid
  amount     Decimal           @db.Decimal(12, 2)
  currency   String            @default("USD")
  status     TransactionStatus @default(pending)
  type       TransactionType
  reference  String?           @unique
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  listing WasteListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  payer   User          @relation("PayerTransactions", fields: [payerId], references: [id], onDelete: Cascade)
  payee   User          @relation("PayeeTransactions", fields: [payeeId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([payerId])
  @@index([payeeId])
  @@map("transactions")
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  listingId  String   @map("listing_id") @db.Uuid
  fromUserId String   @map("from_user_id") @db.Uuid
  toUserId   String   @map("to_user_id") @db.Uuid
  score      Int
  body       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  listing WasteListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  fromUser User         @relation("reviews_from", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User         @relation("reviews_to", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("reviews")
}

model PlatformSettings {
  id                             Int      @id @default(1)
  defaultDriverCommissionPercent Decimal  @default(10) @map("default_driver_commission_percent") @db.Decimal(5, 2)
  updatedAt                      DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model Notification {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  type           String
  title          String
  body           String?
  readAt         DateTime? @map("read_at")
  listingId      String?   @map("listing_id") @db.Uuid
  conversationId String?   @map("conversation_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}
