// Prisma schema — Waste Marketplace (Phase 2: offers, comments, chat, pricing)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  customer
  buyer
  admin
}

enum WasteType {
  PLASTIC
  PAPER
  CARDBOARD
  METAL
  GLASS
  E_WASTE
  ORGANIC
  MIXED
  CUSTOM
}

enum ListingStatus {
  open
  accepted
  completed
  cancelled
}

enum OfferStatus {
  pending
  accepted
  declined
  withdrawn
}

/// Application profile keyed to auth.users.id (Supabase Auth).
model User {
  id        String   @id @db.Uuid
  name      String
  email     String   @unique
  phone     String?
  role      UserRole
  address   String?
  createdAt DateTime @default(now()) @map("created_at")

  listingsPosted   WasteListing[]    @relation("SellerListings")
  listingsAccepted WasteListing[]    @relation("AcceptedBy")
  offersMade       Offer[]
  comments         ListingComment[]
  buyerConversations Conversation[]
  messagesSent     Message[]

  @@map("users")
}

model WasteListing {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  wasteType    WasteType     @map("waste_type")
  quantity     String
  description  String?
  images       String[]      @default([])
  address      String
  askingPrice  Decimal       @map("asking_price") @db.Decimal(12, 2)
  currency     String        @default("USD")
  status       ListingStatus @default(open)
  acceptedById String?       @map("accepted_by") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  seller User               @relation("SellerListings", fields: [userId], references: [id], onDelete: Cascade)
  acceptor    User?              @relation("AcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)
  offers      Offer[]
  comments    ListingComment[]
  conversations Conversation[]

  @@index([status])
  @@index([userId])
  @@index([acceptedById])
  @@map("waste_listings")
}

model Offer {
  id        String      @id @default(uuid()) @db.Uuid
  listingId String      @map("listing_id") @db.Uuid
  buyerId   String      @map("buyer_id") @db.Uuid
  amount    Decimal     @db.Decimal(12, 2)
  currency  String      @default("USD")
  status    OfferStatus @default(pending)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  listing WasteListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User         @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([buyerId])
  @@map("offers")
}

model ListingComment {
  id        String   @id @default(uuid()) @db.Uuid
  listingId String   @map("listing_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  listing WasteListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_comments")
}

/// One thread per listing + buyer; seller is listing owner.
model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  listingId String   @map("listing_id") @db.Uuid
  buyerId   String   @map("buyer_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  listing  WasteListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User         @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([listingId, buyerId])
  @@index([listingId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}
